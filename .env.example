# サイトの公開URL（独自ドメイン接続後に差し替え）。末尾スラッシュなし。
NEXT_PUBLIC_SITE_URL=https://nurse-nigemichi.example.com

# Formspree のフォームID（https://formspree.io で作成 → 例: xqkzabcd）
# 未設定の場合、/contact は代替の公開メール表示にフォールバックします。
NEXT_PUBLIC_FORMSPREE_ID=

# 問い合わせ用の公開メール（Formspree未設定時のフォールバック表示に使用）
NEXT_PUBLIC_CONTACT_EMAIL=contact@example.com

# Google Analytics 4 測定ID（例: G-XXXXXXXXXX）。未設定なら読み込みません。
NEXT_PUBLIC_GA_ID=

# Google Search Console のサイト所有権確認コード（content属性の値のみ）。任意。
NEXT_PUBLIC_GSC_VERIFICATION=
